{
  "compilerOptions": {
    "target":                          "ES2022",
    "module":                          "commonjs",
    "lib":                             ["ES2022"],
    "strict":                          true,
    "esModuleInterop":                 true,
    "skipLibCheck":                    true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule":               true,
    "declaration":                     true,
    "declarationMap":                  true,
    "sourceMap":                       true,
    "composite":                       true
  },
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/accounts" },
    { "path": "packages/ingester" },
    { "path": "packages/api" },
    { "path": "packages/bot" }
  ]
}
