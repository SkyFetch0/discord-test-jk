# ═══════════════════════════════════════════════════════════════════════════════
# Senneo — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala ve gerçek değerleri gir.
# .env dosyasını git'e commit ETME.
# ═══════════════════════════════════════════════════════════════════════════════

# ── ScyllaDB (Operational Tables) ─────────────────────────────────────────────
SCYLLA_HOSTS=localhost
SCYLLA_KEYSPACE=senneo
SCYLLA_CQL_PORT=9042

# ── ClickHouse (Primary Message Store) ────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=senneo_messages
CLICKHOUSE_MSG_DB=senneo_messages
CLICKHOUSE_USR_DB=senneo_users
CH_HTTP_PORT=8123
CH_NATIVE_PORT=9000

# ── Kafka / Redpanda ──────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=messages
KAFKA_PORT=9092
KAFKA_PARTITIONS=16

# ── API ────────────────────────────────────────────────────────────────────────
PORT=4000
API_PORT=4000
NODE_ENV=development

# ── Bot (Discord selfbot → Kafka) ─────────────────────────────────────────────
BOT_TOKEN=

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-in-production
ADMIN_PASSWORD=admin123

# ── Monitoring ─────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# ── Target Guild/Channel (Scraper) ────────────────────────────────────────────
TARGET_GUILD_IDS=
TARGET_CHANNEL_IDS=
SCRAPE_HISTORY_ENABLED=true
MAX_CONCURRENT_GUILDS=5

# ── Ingester Settings ─────────────────────────────────────────────────────────
INGESTER_BATCH_FLUSH_SIZE=2000
INGESTER_MAX_BYTES=104857600
INGESTER_MAX_BYTES_PER_PARTITION=8388608
INGESTER_MIN_BYTES=1
INGESTER_MAX_WAIT_TIME_MS=250
INGESTER_PARTITIONS_CONSUMED_CONCURRENTLY=8
