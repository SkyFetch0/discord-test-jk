# Auth
JWT_SECRET=senneo-jwt-secret-change-this-in-production-2026
ADMIN_PASSWORD=admin123

# ScyllaDB
SCYLLA_HOSTS=localhost
SCYLLA_KEYSPACE=senneo

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=senneo_messages

# Kafka/Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=messages

# Target Guilds (comma-separated for multiple)
TARGET_GUILD_IDS=727881213406347282

# Optional: Specific channels to scrape (comma-separated)
TARGET_CHANNEL_IDS=1307528453079171122

# Scrape history
SCRAPE_HISTORY=true

# Concurrent guilds (default: 5) - Max 5 kanal/hesap
CONCURRENT_GUILDS=5
SCRAPE_TARGETS=727881213406347282:1307528453079171122,319560327719026709:361511298451767297,549470467522560011:549474735684059136,679875946597056683:679877028991860876,125440014904590336:404440555355897879,125440014904590336:588711260237856793,125440014904590336:1237977768722174033

# Scraper Configuration - Discord API rate limit compliant
SCRAPE_BATCH_SIZE=100
FETCH_DELAY_MS=300
ADAPTIVE_MIN_MS=120
ADAPTIVE_MAX_MS=2000
RATE_LIMIT_COOLDOWN_MS=10000
MAX_BATCHES_PER_RUN=50

# Worker Configuration
SCRAPER_WORKER_ID=accounts-1
LOGIN_CONCURRENCY=10
LOGIN_DELAY_MS=1500
