<!-- ─────────────────────────────────────────────────────────────────────────
     storage.xml — Senneo ClickHouse Depolama Yapılandırması (DEV)
     ClickHouse 24.8+: default disk path top-level <path> elementinde olmalı.
     storage_configuration sadece ek diskler ve policy'ler için kullanılır.
     ───────────────────────────────────────────────────────────────────────── -->
<clickhouse>

    <!-- ClickHouse 24.8+ requires this top-level path for the default disk -->
    <path>/var/lib/clickhouse/</path>

    <tmp_path>/var/lib/clickhouse/tmp/</tmp_path>
    <user_files_path>/var/lib/clickhouse/user_files/</user_files_path>

    <!--
    ═══════════════════════════════════════════════════════════════
    OPSİYONEL: Tiered Storage (SSD + HDD)
    ═══════════════════════════════════════════════════════════════
    Etkinleştirmek için:
      1. Aşağıdaki bloğun comment'ini kaldır
      2. Docker volume'ları NVMe ve HDD mount point'lerine bağla
      3. messages tablosu için: SETTINGS storage_policy = 'tiered'

    <storage_configuration>
        <disks>
            <hot>
                <path>/var/lib/clickhouse/hot/</path>
            </hot>
            <cold>
                <path>/var/lib/clickhouse/cold/</path>
            </cold>
        </disks>
        <policies>
            <tiered>
                <volumes>
                    <hot_volume>
                        <disk>hot</disk>
                        <max_data_part_size_bytes>5368709120</max_data_part_size_bytes>
                    </hot_volume>
                    <cold_volume>
                        <disk>cold</disk>
                    </cold_volume>
                </volumes>
                <move_factor>0.1</move_factor>
            </tiered>
        </policies>
    </storage_configuration>
    -->

</clickhouse>
