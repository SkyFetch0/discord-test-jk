<!-- ─────────────────────────────────────────────────────────────────────────
     default.xml — Senneo ClickHouse Kullanıcı ve Profil Yapılandırması (DEV)
     Production'da PLACEHOLDER_HASH'leri gerçek SHA-256 ile değiştir.
     ───────────────────────────────────────────────────────────────────────── -->
<clickhouse>

    <profiles>

        <!-- Default profile — async insert ayarları burada olmalı (user-level) -->
        <default>
            <async_insert>1</async_insert>
            <wait_for_async_insert>1</wait_for_async_insert>
            <async_insert_max_data_size>10485760</async_insert_max_data_size>
            <async_insert_busy_timeout_ms>2000</async_insert_busy_timeout_ms>
            <async_insert_max_query_number>500</async_insert_max_query_number>
            <async_insert_deduplicate>1</async_insert_deduplicate>
            <insert_deduplicate>1</insert_deduplicate>
            <max_memory_usage>8589934592</max_memory_usage>
            <max_insert_block_size>500000</max_insert_block_size>
            <max_partitions_per_insert_block>256</max_partitions_per_insert_block>
            <max_execution_time>60</max_execution_time>
        </default>

    </profiles>

    <users>
        <default>
            <password></password>
            <profile>default</profile>
            <quota>default</quota>
            <networks>
                <ip>::/0</ip>
            </networks>
            <access_management>1</access_management>
        </default>
    </users>

    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>

</clickhouse>
