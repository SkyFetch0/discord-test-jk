{
  "name": "senneo",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build":          "npm run build -w @senneo/shared && npm run build -w @senneo/accounts && npm run build -w @senneo/ingester && npm run build -w @senneo/api && npm run build -w @senneo/bot",
    "dev:accounts":   "npm run dev   -w @senneo/accounts",
    "dev:ingester":   "npm run dev   -w @senneo/ingester",
    "dev:api":        "npm run dev   -w @senneo/api",
    "start:accounts": "node -r dotenv/config packages/accounts/dist/index.js",
    "start:ingester": "node -r dotenv/config packages/ingester/dist/index.js",
    "start:api":      "node -r dotenv/config packages/api/dist/index.js"
  },
  "devDependencies": {
    "typescript":  "^5.3.3",
    "@types/node": "^20.10.5"
  }
}