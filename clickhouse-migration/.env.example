# ─────────────────────────────────────────────────────────────────────────────
# Senneo ClickHouse — Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyala ve gerçek şifreleri gir.
# .env dosyasını git'e commit ETME.
# ─────────────────────────────────────────────────────────────────────────────

# Ingester kullanıcısının şifresi (INSERT/SELECT erişimi)
CH_INGESTER_PASSWORD=guclu_bir_sifre_yaz

# API kullanıcısının şifresi (sadece SELECT + users_latest UPDATE)
CH_API_PASSWORD=baska_bir_sifre_yaz

# Dashboard kullanıcısının şifresi (sadece analytics SELECT)
CH_DASHBOARD_PASSWORD=ucuncu_bir_sifre

# ─────────────────────────────────────────────────────────────────────────────
# SHA-256 hash üretmek için (users.d/default.xml'e koyulacak):
#   echo -n "sifren" | sha256sum
# ─────────────────────────────────────────────────────────────────────────────
